# Hostinger Node.js (Passenger)
# Ensure ALL requests go through Node.js, not served by Apache directly

DirectoryIndex disabled

RewriteEngine On

# Pass everything through to Node.js/Passenger
# The [PT] flag passes to the next handler (Passenger) instead of proxying
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ /$1 [L,PT]
